{
  "name": "@galaxis/server",
  "version": "0.0.0",
  "private": true,
  "description": "Serverautoritativer Galaxis-Server",
  "type": "module",
  "engines": {
    "node": "24.18.0"
  },
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "architecture:check": "node scripts/check-architecture.mjs && depcruise --validate .dependency-cruiser.cjs src",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/app/composition-root/main.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "start": "node dist/app/composition-root/main.js",
    "test": "vitest run",
    "test:contract": "vitest run --passWithNoTests tests/contract",
    "test:integration": "vitest run --passWithNoTests tests/integration",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm architecture:check && pnpm build"
  },
  "dependencies": {
    "@fastify/type-provider-typebox": "6.1.0",
    "@sinclair/typebox": "0.34.52",
    "argon2": "0.45.1",
    "fastify": "5.10.0",
    "kysely": "0.29.4",
    "pg": "8.22.0",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "dependency-cruiser": "18.1.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "prettier": "3.9.6",
    "testcontainers": "12.0.4",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10"
  }
}
