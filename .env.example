GALAXIS_PORT=3000
GALAXIS_LOG_LEVEL=info
GALAXIS_SERVICE_NAME=galaxis-server
GALAXIS_SHUTDOWN_TIMEOUT_MS=10000
GALAXIS_MAX_BODY_BYTES=1048576
GALAXIS_REQUEST_TIMEOUT_MS=30000
GALAXIS_CONNECTION_TIMEOUT_MS=30000
